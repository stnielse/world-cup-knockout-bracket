# Template for .env. Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is checked in.
# In production (Render), set these as env vars in the dashboard instead of
# committing a .env file.

# Django secret key.
# Required in prod (prod.py raises if missing). Optional in dev — dev.py
# has an insecure fallback so the app boots without it.
# Generate one with:
#   .venv/bin/python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Comma-separated list of hostnames Django will serve.
# Required in prod. Examples:
#   ALLOWED_HOSTS=wc26-bracket.onrender.com
#   ALLOWED_HOSTS=wc26-bracket.onrender.com,bracket.example.com
ALLOWED_HOSTS=

# Resend API key for outbound password-reset emails.
# Required in prod once email is wired (Phase 2). Optional in dev — dev.py
# uses the console email backend, so emails print to the terminal locally.
# Get an API key from https://resend.com/api-keys.
# RESEND_API_KEY=
